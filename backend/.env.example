# fettle backend — optional overrides (copy to backend/.env to use).
# The defaults already match the documented ports — backend 8400, frontend 3400 —
# so a fresh install needs no .env at all. Uncomment only what you change.

# Must be registered as an Authorized redirect URI on your OAuth client:
# oauth_redirect_uri=http://localhost:8400/auth/callback

# Origins allowed to call the API (the dashboard):
# cors_origins=["http://localhost:3400","http://127.0.0.1:3400"]

# Where the OAuth callback sends the browser after connecting:
# frontend_url=http://localhost:3400

# First-sync reach (days). Intraday is deliberately short — heart-rate is sub-minute:
# initial_backfill_days=90
# initial_intraday_days=3
